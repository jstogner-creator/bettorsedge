# GEMINI_API_KEY: Required for Gemini AI API calls. Use only the key from "Kalshi betting app" project.
GEMINI_API_KEY=

# OPENAI_API_KEY: Optional for OpenAI API calls.
OPENAI_API_KEY=

# Kalshi API Credentials
KALSHI_API_KEY=
KALSHI_API_SECRET=
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2

# APP_URL: The URL where this applet is hosted.
APP_URL=

# Stripe Configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# Sportradar API Key
# Note: Sportradar has different keys for different products.
# You likely need an "NBA" key and an "Odds Comparison" key.
# If you see 403 errors, ensure your key is for the correct sport and region.
SPORTRADAR_API_KEY=
