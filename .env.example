# GEMINI_API_KEY: Required for Gemini AI API calls. Use only the key from "Kalshi sports analysis" project.
GEMINI_API_KEY=

# OPENAI_API_KEY: Optional for OpenAI API calls.
OPENAI_API_KEY=

# Kalshi API Credentials
KALSHI_API_KEY=
KALSHI_API_SECRET=
KALSHI_BASE_URL=https://trading-api.kalshi.com/trade-api/v2

# APP_URL: The URL where this applet is hosted.
APP_URL=

# Stripe Configuration
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# API-Sports NBA API Key
# Documentation: https://api-sports.io/documentation/nba/v2
API_SPORTS_KEY=
